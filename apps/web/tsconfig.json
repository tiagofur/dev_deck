{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["vite/client"],
    "paths": {
      "@devdeck/ui": ["../../packages/ui/src/index.ts"],
      "@devdeck/ui/*": ["../../packages/ui/*"],
      "@devdeck/api-client": ["../../packages/api-client/src/index.ts"],
