{
  "manifest_version": 3,
  "name": "DevDeck — Quick Capture v2",
  "description": "Guardá cualquier cosa en tu DevDeck con Cmd/Ctrl+Shift+D. Ahora con React y Sync.",
  "version": "0.3.0",
  "action": {
    "default_popup": "src/popup/index.html"
  },
  "content_scripts": [
    {
      "js": ["src/content/index.tsx"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "permissions": ["activeTab", "storage", "alarms", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "capture-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+D",
        "mac": "Command+Shift+D"
      },
      "description": "Capturar la tab activa en DevDeck"
    }
  }
}
