{
  "name": "devdeck-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "DevDeck — your personal dev multi-tool. Desktop app.",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
