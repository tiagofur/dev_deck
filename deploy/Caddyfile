# Caddyfile — DevDeck reverse proxy with automatic HTTPS
#
# {$DOMAIN} comes from the environment (set in .env / docker-compose).
# Caddy provisions a Let's Encrypt cert automatically the first time
# the domain resolves to this server.

{$API_DOMAIN} {
    encode gzip zstd

    handle /healthz {
        reverse_proxy api:8080
    }

    handle /api/* {
        reverse_proxy api:8080
    }

    handle {
        respond "DevDeck API" 200
    }

    log {
        output stdout
        format console
        level INFO
    }
}

{$APP_DOMAIN} {
    encode gzip zstd
    reverse_proxy web:80

    log {
        output stdout
        format console
        level INFO
    }
}

{$DOMAIN} {
    redir https://{$APP_DOMAIN}{uri} permanent
}
