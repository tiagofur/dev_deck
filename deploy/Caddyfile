# Caddyfile — DevDeck reverse proxy with automatic HTTPS
#
# {$DOMAIN} comes from the environment (set in .env / docker-compose).
# Caddy provisions a Let's Encrypt cert automatically the first time
# the domain resolves to this server.

{$DOMAIN} {
    encode gzip zstd

    # Health check is public
    handle /healthz {
        reverse_proxy api:8080
    }

    # API proxy
    handle /api/* {
        reverse_proxy api:8080
    }

    # SPA — serve React app for all other routes (including root)
    handle /* {
        reverse_proxy web:3000
    }

    log {
        output stdout
        format console
        level INFO
    }
}
